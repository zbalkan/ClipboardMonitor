<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net481</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>ClipboardMonitor</RootNamespace>
    <AssemblyName>ClipboardMonitor</AssemblyName>

    <!-- Assembly Metadata from AssemblyInfo.cs -->
    <Title>ClipboardMonitor</Title>
    <Product>ClipboardMonitor</Product>
    <Company>Zafer Balkan</Company>
    <Copyright>Copyright © 2025</Copyright>
    <Version>2.1.0.0</Version>
    <FileVersion>2.1.0.0</FileVersion>
    
    <ApplicationIcon>Assets\icon.ico</ApplicationIcon>
    <StartupObject>ClipboardMonitor.Program</StartupObject>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Deterministic>true</Deterministic>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <PackageProjectUrl>https://github.com/zbalkan/ClipboardMonitor</PackageProjectUrl>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/zbalkan/ClipboardMonitor</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <!-- SDK Contracts for ToastNotifications and WinRT access -->
    <PackageReference Include="Microsoft.Windows.SDK.Contracts" Version="10.0.28000.1839" />
    <PackageReference Include="Nullable" Version="1.3.1" PrivateAssets="all" />
  </ItemGroup>


  <ItemGroup>
    <EmbeddedResource Include="Assets\icon.png" />
    <EmbeddedResource Include="Assets\icon-inverted.png" />
    <None Update="Assets\icon.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>